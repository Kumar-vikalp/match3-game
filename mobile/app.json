{
  "expo": {
    "name": "Gem Crush",
    "slug": "gem-crush",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gemcrush",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kumarvikalp.gemcrush"
    },
    "android": {
      "package": "com.kumarvikalp.gemcrush",
      "adaptiveIcon": {
        "backgroundColor": "#0a0118",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "220a9d17-03c2-4ead-8a57-12ac8b4ee856"
      }
    },
    "owner": "killm0nger"
  }
}
